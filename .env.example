# Copy to .env.local and fill with real values (.env.local is gitignored).
# Real secrets are never committed; a human sets them (see specs/002-auth-and-projects/setup.md).

# Supabase (ADR-0006) — project API URL + keys.
# Public values are sent to the browser (NEXT_PUBLIC_*); the service-role key is server-only.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon public key>
SUPABASE_SERVICE_ROLE_KEY=<service_role secret key — server only, never NEXT_PUBLIC>

# GitHub member-activity integration (spec 012) — server-only, optional.
# A single org-read token + the org's GraphQL node id power the contribution graph and
# commit list for every member. Absent ⇒ activity shows an "unavailable" state (fail-soft).
GITHUB_TOKEN=<github token with org + repo read (PAT or GitHub App token)>
GITHUB_ORG_ID=<the org's GraphQL node id, e.g. O_kgDO... — used for contributionsCollection>
# Optional: override the GitHub org login used for the sign-in membership gate (default ProgixDev).
# PROGIX_GITHUB_ORG=ProgixDev
