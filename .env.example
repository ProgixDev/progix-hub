# Copy to .env.local and fill in real values (never commit real env files).
# Every variable here must be parsed in src/core/env.ts — unparsed env access fails review.

# NODE_ENV is set by Next.js automatically.

# Example server-side variable (uncomment in src/core/env.ts schema too):
# DATABASE_URL="postgres://user:password@localhost:5432/app"

# Client-exposed variables must be prefixed NEXT_PUBLIC_ and justified in review:
# NEXT_PUBLIC_ANALYTICS_ID=""
